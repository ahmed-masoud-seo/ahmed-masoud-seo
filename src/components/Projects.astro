---

<section class="projects" id="projects">

  <div class="container">

    <span class="section-badge">
      أبرز أعمالي
    </span>

    <h2>
      نماذج من المشاريع التي عملت عليها
    </h2>

    <div class="projects-grid">

      {
        projects.map(project => (

          <div class="project-card">

            <img
              class="project-cover"
              src={project.image}
              alt={project.title}
              loading="lazy"
              decoding="async"
              fetchpriority="low"
            />

            <div class="project-content">

              <img
                class="project-logo"
                src={project.logo}
                alt={project.title}
                loading="lazy"
                decoding="async"
                fetchpriority="low"
              />

              <h3>{project.title}</h3>

              <p>{project.description}</p>

              <div class="project-services">

                {
                  project.services.map(service => (
                    <span>✔ {service}</span>
                  ))
                }

              </div>

              <div class="project-result">

                <h4>ما الذي تم إنجازه؟</h4>

                <p>{project.result}</p>

              </div>

              <div class="project-type">

                🏷️ {project.type}

              </div>

            </div>

          </div>

        ))
      }

    </div>

  </div>

</section>