---
const faqs = [
  {
    question: "ما هو SEO؟",
    answer:
      "SEO أو تحسين محركات البحث هو مجموعة من الاستراتيجيات والتقنيات التي تساعد على تحسين ظهور المواقع والمتاجر الإلكترونية في نتائج البحث المجانية على Google. يشمل ذلك تحسين السيو التقني، وتحسين المحتوى، والبحث عن الكلمات المفتاحية، وبناء الروابط الداخلية، بهدف زيادة الزيارات العضوية وتحقيق نمو مستدام للموقع."
  },
  {
    question: "كم يستغرق ظهور نتائج SEO؟",
    answer:
      "تختلف مدة ظهور نتائج تحسين محركات البحث حسب عمر الموقع، وحجم المنافسة، وجودة المحتوى، وحالة السيو التقني. في معظم الحالات تبدأ النتائج الأولية في الظهور خلال 3 إلى 6 أشهر، بينما تحتاج الكلمات المفتاحية التنافسية إلى وقت أطول لتحقيق مراكز متقدمة في نتائج بحث Google."
  },
  {
    question: "هل تعمل على تحسين SEO لمتاجر سلة؟",
    answer:
      "نعم، أقدم خدمات SEO لمتاجر سلة تشمل تحسين صفحات المنتجات، وصفحات التصنيفات، وتحسين السيو التقني، والبحث عن الكلمات المفتاحية، وتحسين تجربة المستخدم، وبناء استراتيجية محتوى تساعد المتجر على زيادة الزيارات العضوية وتحسين الظهور في نتائج البحث."
  },
  {
    question: "هل تقدم استشارات SEO؟",
    answer:
      "نعم، أقدم استشارات SEO للمواقع والمتاجر الإلكترونية، وتشمل تحليل الموقع، واكتشاف المشكلات التقنية، ووضع خطة لتحسين ترتيب الكلمات المفتاحية، وزيادة الزيارات العضوية، وتحسين الأداء العام في محركات البحث."
  },
  {
    question: "ما هي خدمات SEO التي تقدمها؟",
    answer:
      "تشمل خدماتي تحليل SEO شامل، والسيو التقني، وتحسين صفحات الموقع، والبحث عن الكلمات المفتاحية، وتحسين المحتوى، وتحسين سرعة الموقع، وتهيئة متاجر سلة وWordPress لمحركات البحث، مع التركيز على زيادة الزيارات المجانية وتحسين ترتيب الموقع في Google."
  },
  {
    question: "لماذا تختار العمل معي في خدمات SEO؟",
    answer:
      "أعتمد على تحليل البيانات، وأفضل ممارسات تحسين محركات البحث، وخطط عمل واضحة تناسب كل موقع أو متجر إلكتروني. أركز على تحسين السيو التقني، وتحسين المحتوى، واستهداف الكلمات المفتاحية المناسبة، مع متابعة الأداء باستمرار لتحقيق نمو مستدام في نتائج البحث."
  }
];
---

<script
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((faq) => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer
      }
    }))
  })}
/>

<section class="faq-section" id="faq">

  <div class="container">

    <div class="faq-header">

      <span class="section-badge">
        الأسئلة الشائعة
      </span>

      <h2>
        الأسئلة الشائعة حول خدمات SEO
      </h2>

      <p class="section-description">
        إليك إجابات عن أكثر الأسئلة شيوعًا حول تحسين محركات البحث وخدمات SEO للمواقع والمتاجر الإلكترونية.
      </p>

    </div>

    <div class="faq-list">

      {
        faqs.map((faq) => (

          <details class="faq-item">

            <summary>
              {faq.question}
            </summary>

            <div class="faq-content">
              <p>{faq.answer}</p>
            </div>

          </details>

        ))
      }

    </div>

  </div>

</section>

<style>

.faq-section{

padding:110px 0;

background:#f8fafc;

}

.faq-header{

max-width:850px;

margin:0 auto 60px;

text-align:center;

}

.section-badge{

display:inline-block;

padding:10px 18px;

background:#DBEAFE;

color:#2563EB;

border-radius:999px;

font-weight:700;

font-size:15px;

margin-bottom:20px;

}

.faq-header h2{

font-size:42px;

font-weight:800;

margin-bottom:20px;

color:#111827;

}

.section-description{

font-size:18px;

line-height:2;

color:#64748b;

margin:0;

}

.faq-list{

max-width:900px;

margin:0 auto;

display:flex;

flex-direction:column;

gap:22px;

}

.faq-item{

background:#fff;

border-radius:18px;

box-shadow:0 10px 30px rgba(0,0,0,.06);

transition:.3s;

overflow:hidden;

}

.faq-item:hover{

transform:translateY(-4px);

box-shadow:0 18px 40px rgba(0,0,0,.08);

}

.faq-item summary{

list-style:none;

cursor:pointer;

padding:24px 30px;

display:flex;

justify-content:space-between;

align-items:center;

font-size:20px;

font-weight:700;

}

.faq-item summary::-webkit-details-marker{

display:none;

}

.faq-item summary::after{

content:"+";

font-size:30px;

font-weight:700;

color:#2563EB;

transition:.3s;

}

.faq-item[open] summary::after{

content:"−";

}

.faq-content{

padding:0 30px 28px;

}

.faq-content p{

font-size:17px;

line-height:2;

color:#475569;

margin:0;

}

@media (max-width:768px){

.faq-section{

padding:80px 0;

}

.faq-header{

margin-bottom:40px;

padding:0 20px;

}

.faq-header h2{

font-size:30px;

}

.section-description{

font-size:16px;

}

.faq-item summary{

padding:20px;

font-size:17px;

}

.faq-content{

padding:0 20px 20px;

}

.faq-content p{

font-size:16px;

}

}

</style>