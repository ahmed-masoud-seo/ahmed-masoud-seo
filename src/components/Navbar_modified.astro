---
const links = [
  { title: "الرئيسية", href: "#home" },
  { title: "من أنا", href: "#about" },
  { title: "خدمات SEO", href: "#services" },
  { title: "المشاريع", href: "#projects" },
  { title: "الشهادات", href: "#certificates" },
  { title: "تواصل", href: "#contact" },
];
---

<header class="navbar">

  <div class="container navbar-container">

    <button
      class="menu-toggle"
      id="menuToggle"
      aria-label="فتح القائمة"
    >
      ☰
    </button>

    <a href="#home" class="brand">

      <img src="/profile.png" alt="Ahmed Masoud" />

      <div>

        <h3>أحمد مسعود</h3>

        <p>SEO Specialist</p>

      </div>

    </a>

    <nav>

      {
        links.map((link) => (

          <a href={link.href}>
            {link.title}
          </a>

        ))
      }

    </nav>

    <a
      href="https://wa.me/201141289932"
      target="_blank"
      rel="noopener noreferrer"
      class="contact-btn"
    >
      احجز استشارة SEO
    </a>

  </div>

  <div class="menu-overlay" id="menuOverlay"></div>

  <aside class="mobile-menu" id="mobileMenu">

    <div class="mobile-header">

      <h3>القائمة</h3>

      <button id="closeMenu">✕</button>

    </div>

    <nav class="mobile-nav">

      {
        links.map((link) => (

          <a
            href={link.href}
            class="mobile-link"
          >
            {link.title}
          </a>

        ))
      }

    </nav>

    <a
      href="https://wa.me/201141289932"
      target="_blank"
      rel="noopener noreferrer"
      class="mobile-contact-btn"
    >
      احجز استشارة SEO
    </a>

  </aside>

</header>

<style>
.navbar{

position:fixed;

top:0;

left:0;

right:0;

background:rgba(255,255,255,.96);

backdrop-filter:blur(10px);

box-shadow:0 8px 25px rgba(0,0,0,.05);

z-index:999;

}

.navbar-container{

display:flex;

justify-content:space-between;

align-items:center;

height:82px;

}

.brand{

display:flex;

align-items:center;

gap:15px;

text-decoration:none;

}

.brand img{

width:56px;

height:56px;

border-radius:50%;

object-fit:cover;

}

.brand h3{

font-size:22px;

margin:0;

color:#111827;

font-weight:800;

}

.brand p{

margin-top:4px;

font-size:15px;

color:#6b7280;

}

nav{

display:flex;

gap:34px;

}

nav a{

text-decoration:none;

color:#374151;

font-weight:700;

transition:.3s;

position:relative;

}

nav a::after{

content:"";

position:absolute;

bottom:-8px;

left:0;

width:0;

height:2px;

background:#2563eb;

transition:.3s;

}

nav a:hover{

color:#2563eb;

}

nav a:hover::after{

width:100%;

}

.contact-btn{

background:#2563eb;

color:#fff;

padding:14px 24px;

border-radius:12px;

font-weight:700;

text-decoration:none;

transition:.3s;

}

.contact-btn:hover{

background:#1d4ed8;

transform:translateY(-3px);

}

.menu-toggle{

display:none;

background:none;

border:none;

font-size:32px;

cursor:pointer;

color:#2563eb;

padding:0;

}

.menu-overlay{

position:fixed;

inset:0;

background:rgba(0,0,0,.45);

opacity:0;

visibility:hidden;

transition:.3s;

z-index:998;

}

.mobile-menu{

position:fixed;
transform:translateX(30px);
opacity:0;

top:0;

right:-320px;

width:300px;

height:100vh;

background:#fff;

padding:30px 24px;

display:flex;

flex-direction:column;

box-shadow:-8px 0 25px rgba(0,0,0,.12);

transition:right .35s ease, transform .35s ease, opacity .25s ease;

z-index:999;

}

.mobile-menu.active{

right:0;
transform:translateX(0);
opacity:1;
}

.menu-overlay.active{

opacity:1;

visibility:visible;

}

.mobile-header{

display:flex;

justify-content:space-between;

align-items:center;

margin-bottom:35px;

}

.mobile-header h3{

margin:0;

font-size:22px;

}

.mobile-header button{

background:none;

border:none;

font-size:28px;

cursor:pointer;

}

.mobile-nav{

display:flex;

flex-direction:column;

gap:22px;

}

.mobile-link{

text-decoration:none;

font-weight:700;

font-size:18px;

color:#374151;

transition:.3s;

}

.mobile-link:hover{

color:#2563eb;

}

.mobile-contact-btn{

margin-top:auto;

background:#2563eb;

color:#fff;

text-decoration:none;

padding:15px;

text-align:center;

border-radius:12px;

font-weight:700;

transition:.3s;

}

.mobile-contact-btn:hover{

background:#1d4ed8;

}

@media(max-width:900px){

nav{

display:none;

}

.contact-btn{

display:none;

}

.menu-toggle{

display:block;

order:1;

}

.brand{

order:2;

margin-inline-start:auto;

}

.brand img{

width:46px;

height:46px;

}

.brand h3{

font-size:19px;

}

.brand p{

font-size:12px;

}

.navbar-container{

height:74px;

}

.brand img{
display:none;
}
.brand{gap:0;}

}

</style>

<script>
const toggle = document.getElementById("menuToggle");
const close = document.getElementById("closeMenu");
const menu = document.getElementById("mobileMenu");
const overlay = document.getElementById("menuOverlay");

function openMenu() {
  menu.classList.add("active");
  overlay.classList.add("active");
  document.body.style.overflow = "hidden";
}

function closeMenu() {
  menu.classList.remove("active");
  overlay.classList.remove("active");
  document.body.style.overflow = "";
}

toggle?.addEventListener("click", openMenu);

close?.addEventListener("click", closeMenu);

overlay?.addEventListener("click", closeMenu);

document.querySelectorAll(".mobile-link").forEach((link) => {
  link.addEventListener("click", closeMenu);
});
</script>