---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
---

<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>

  <!-- Basic -->
  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <!-- SEO -->

  <title>
    أحمد مسعود | متخصص تحسين محركات البحث (SEO) للمواقع والمتاجر الإلكترونية
  </title>

  <meta
    name="description"
    content="أحمد مسعود متخصص SEO يساعد أصحاب المواقع والمتاجر الإلكترونية ومتاجر سلة على زيادة الزيارات العضوية وتحسين ترتيب الكلمات المفتاحية وتحقيق نمو مستدام من خلال استراتيجيات عملية تعتمد على البيانات والنتائج."
  />

  <meta
    name="keywords"
    content="Ahmed Masoud, أحمد مسعود, SEO, متخصص SEO, خبير SEO, تحسين محركات البحث, Technical SEO, On Page SEO, Off Page SEO, SEO Audit, Keyword Research, Content Strategy, E-commerce SEO, SEO لمتاجر سلة, WordPress SEO"
  />

  <meta
    name="author"
    content="Ahmed Masoud"
  />

  <meta
    name="robots"
    content="index, follow"
  />

  <meta
    name="googlebot"
    content="index, follow"
  />

  <meta
    name="language"
    content="Arabic"
  />

  <meta
    name="theme-color"
    content="#2563EB"
  />

  <!-- Canonical -->

  <link
    rel="canonical"
    href="https://ahmed-masoud-seo.vercel.app/"
  />

  <!-- Open Graph -->

  <meta
    property="og:type"
    content="website"
  />

  <meta
    property="og:locale"
    content="ar_AR"
  />

  <meta
    property="og:site_name"
    content="Ahmed Masoud"
  />

  <meta
    property="og:title"
    content="أحمد مسعود | متخصص تحسين محركات البحث (SEO)"
  />

  <meta
    property="og:description"
    content="متخصص SEO يساعد أصحاب المواقع والمتاجر الإلكترونية ومتاجر سلة على زيادة الزيارات العضوية وتحسين ترتيب نتائج البحث."
  />

  <meta
    property="og:url"
    content="https://ahmed-masoud-seo.vercel.app/"
  />

  <meta
    property="og:image"
    content="https://ahmed-masoud-seo.vercel.app/og-image.png"
  />

  <meta
    property="og:image:width"
    content="1200"
  />

  <meta
    property="og:image:height"
    content="630"
  />

  <meta
    property="og:image:alt"
    content="Ahmed Masoud - SEO Specialist"
  />

  <!-- Twitter -->

  <meta
    name="twitter:card"
    content="summary_large_image"
  />

  <meta
    name="twitter:title"
    content="أحمد مسعود | متخصص SEO"
  />

  <meta
    name="twitter:description"
    content="متخصص SEO للمواقع والمتاجر الإلكترونية ومتاجر سلة."
  />

  <meta
    name="twitter:image"
    content="https://ahmed-masoud-seo.vercel.app/og-image.png"
  />

  <!-- Structured Data -->

  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://ahmed-masoud-seo.vercel.app/#person",
    "name": "Ahmed Masoud",
    "alternateName": "أحمد مسعود",
    "url": "https://ahmed-masoud-seo.vercel.app/",
    "image": "https://ahmed-masoud-seo.vercel.app/profile.png",
    "jobTitle": "SEO Specialist",
    "description": "SEO Specialist helping websites and e-commerce stores improve organic visibility through Technical SEO, On-Page SEO, Keyword Research and Content Strategy.",
    "email": "mailto:ahmedmasoud.business@gmail.com",

    "sameAs": [
      "https://www.linkedin.com/in/ahmed-masoud95/"
    ],

    "knowsAbout": [
      "SEO",
      "Technical SEO",
      "On-Page SEO",
      "Off-Page SEO",
      "SEO Audit",
      "Keyword Research",
      "Content Strategy",
      "Google Search Console",
      "Google Analytics",
      "Google Tag Manager",
      "Ahrefs",
      "SEMrush",
      "WordPress SEO",
      "Salla SEO",
      "E-commerce SEO"
    ]
  }
  </script>

