  <link
    rel="icon"
    type="image/x-icon"
    href="/favicon.ico"
  />

  <!-- Fonts -->

  <link
    rel="preconnect"
    href="https://fonts.googleapis.com"
  />

  <link
    rel="preconnect"
    href="https://fonts.gstatic.com"
    crossorigin
  />

  <link
    href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;800&display=swap"
    rel="stylesheet"
  />

</head>

<body>

  <Navbar />

  <main>
    <slot />
  </main>

</body>

</html>